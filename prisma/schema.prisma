datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum MatchResult {
  HOME
  DRAW
  AWAY
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  passwordHash String
  role         UserRole     @default(USER)
  isHidden     Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  predictions  Prediction[]
}

model Match {
  id                     String       @id @default(cuid())
  externalId             String       @unique
  homeTeam               String
  awayTeam               String
  homeTeamLogo           String?
  awayTeamLogo           String?
  kickoffTime            DateTime
  stadium                String?
  country                String?
  stage                  String?
  groupName              String?
  round                  String?
  status                 MatchStatus  @default(SCHEDULED)
  homeScore              Int?
  awayScore              Int?
  minute                 Int?
  actualResult           MatchResult?
  source                 String       @default("mock")
  isArchived             Boolean      @default(false)
  providerHomeScore      Int?
  providerAwayScore      Int?
  providerStatus         MatchStatus?
  providerUpdatedAt      DateTime?
  resultSource           String       @default("PROVIDER")
  adminHomeScore         Int?
  adminAwayScore         Int?
  adminStatus            MatchStatus?
  adminResultUpdatedAt   DateTime?
  adminResultUpdatedById String?
  adminNote              String?
  lastSyncedAt           DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  predictions            Prediction[]
}

model Prediction {
  id                 String      @id @default(cuid())
  userId             String
  matchId            String
  predictedHomeScore Int
  predictedAwayScore Int
  predictedResult    MatchResult
  pointsResult       Int         @default(0)
  pointsExactScore   Int         @default(0)
  totalPoints        Int         @default(0)
  isCalculated       Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  match              Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}

model SyncLog {
  id        String   @id @default(cuid())
  provider  String
  jobType   String
  status    String
  message   String?
  createdAt DateTime @default(now())
}
